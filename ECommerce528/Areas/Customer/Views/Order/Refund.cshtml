<style>
        :root {
            --bg: #0a0a0f;
            --surface: #111118;
            --border: #1e1e2e;
            --accent: #00e5a0;
            --accent-dim: rgba(0, 229, 160, 0.12);
            --accent-glow: rgba(0, 229, 160, 0.35);
            --text-primary: #eeeef5;
            --text-muted: #5a5a72;
            --text-sub: #8888a8;
            --danger: #ff4f6a;
            --warning: #ffb347;
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background: var(--bg);
            color: var(--text-primary);
            font-family: 'Syne', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            overflow: hidden;
        }

        /* Background grid */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image:
                linear-gradient(var(--border) 1px, transparent 1px),
                linear-gradient(90deg, var(--border) 1px, transparent 1px);
            background-size: 48px 48px;
            opacity: 0.4;
            z-index: 0;
        }

        /* Radial glow behind card */
        body::after {
            content: '';
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%);
            z-index: 0;
            pointer-events: none;
            animation: pulse 4s ease-in-out infinite;
        }

        @@keyframes pulse {
            0%, 100% { opacity: 0.4; transform: translate(-50%, -50%) scale(1); }
            50%       { opacity: 0.7; transform: translate(-50%, -50%) scale(1.08); }
        }

        .card {
            position: relative;
            z-index: 1;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 3rem 2.5rem;
            width: 100%;
            max-width: 500px;
            box-shadow: 0 0 0 1px var(--border), 0 32px 80px rgba(0,0,0,0.7);
            animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
        }

        @@keyframes slideUp {
            from { opacity: 0; transform: translateY(32px) scale(0.97); }
            to   { opacity: 1; transform: translateY(0)   scale(1);    }
        }

        /* Top accent bar */
        .card::before {
            content: '';
            position: absolute;
            top: -1px; left: 20%; right: 20%;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--accent), transparent);
            border-radius: 0 0 4px 4px;
        }

        /* Icon badge */
        .icon-badge {
            width: 64px;
            height: 64px;
            background: var(--accent-dim);
            border: 1px solid rgba(0, 229, 160, 0.3);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1.5rem;
            animation: iconPop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s both;
        }

        @@keyframes iconPop {
            from { opacity: 0; transform: scale(0.5) rotate(-10deg); }
            to   { opacity: 1; transform: scale(1)   rotate(0deg);   }
        }

        .icon-badge svg {
            width: 28px;
            height: 28px;
            color: var(--accent);
            stroke: var(--accent);
        }

        .tag {
            display: inline-block;
            font-family: 'DM Mono', monospace;
            font-size: 0.65rem;
            font-weight: 500;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--accent);
            background: var(--accent-dim);
            border: 1px solid rgba(0, 229, 160, 0.25);
            padding: 3px 10px;
            border-radius: 100px;
            margin-bottom: 0.85rem;
        }

        h1 {
            font-size: 1.85rem;
            font-weight: 800;
            line-height: 1.15;
            letter-spacing: -0.02em;
            color: var(--text-primary);
            margin-bottom: 0.5rem;
        }

        .subtitle {
            font-size: 0.9rem;
            color: var(--text-sub);
            line-height: 1.6;
            margin-bottom: 2rem;
        }

        /* Divider */
        .divider {
            height: 1px;
            background: var(--border);
            margin: 1.75rem 0;
        }

        /* Detail rows */
        .detail-list {
            display: flex;
            flex-direction: column;
            gap: 0.9rem;
            margin-bottom: 2rem;
        }

        .detail-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
        }

        .detail-label {
            font-family: 'DM Mono', monospace;
            font-size: 0.72rem;
            color: var(--text-muted);
            letter-spacing: 0.08em;
            text-transform: uppercase;
            white-space: nowrap;
        }

        .detail-value {
            font-family: 'DM Mono', monospace;
            font-size: 0.8rem;
            color: var(--text-primary);
            text-align: right;
            word-break: break-all;
        }

        .detail-value.highlight {
            color: var(--accent);
            font-weight: 500;
        }

        .detail-value.badge {
            font-size: 0.7rem;
            background: rgba(255, 179, 71, 0.1);
            color: var(--warning);
            border: 1px solid rgba(255, 179, 71, 0.25);
            padding: 2px 8px;
            border-radius: 100px;
        }

        /* Alert box */
        .alert {
            background: rgba(255, 79, 106, 0.07);
            border: 1px solid rgba(255, 79, 106, 0.2);
            border-radius: 10px;
            padding: 0.85rem 1rem;
            display: flex;
            gap: 0.75rem;
            align-items: flex-start;
            margin-bottom: 2rem;
        }

        .alert svg {
            flex-shrink: 0;
            width: 16px;
            height: 16px;
            color: var(--danger);
            stroke: var(--danger);
            margin-top: 2px;
        }

        .alert p {
            font-size: 0.78rem;
            color: var(--danger);
            line-height: 1.55;
            opacity: 0.85;
        }

        /* Actions */
        .actions {
            display: flex;
            gap: 0.75rem;
        }

        .btn {
            flex: 1;
            padding: 0.75rem 1rem;
            border-radius: 10px;
            font-family: 'Syne', sans-serif;
            font-size: 0.85rem;
            font-weight: 600;
            cursor: pointer;
            border: none;
            text-decoration: none;
            text-align: center;
            transition: all 0.18s ease;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.4rem;
        }

        .btn-primary {
            background: var(--accent);
            color: #05150f;
        }

        .btn-primary:hover {
            background: #00ffb3;
            box-shadow: 0 0 24px var(--accent-glow);
            transform: translateY(-1px);
        }

        .btn-ghost {
            background: transparent;
            color: var(--text-sub);
            border: 1px solid var(--border);
        }

        .btn-ghost:hover {
            background: var(--border);
            color: var(--text-primary);
            transform: translateY(-1px);
        }

        .btn:active {
            transform: translateY(0);
        }

        /* Timestamp */
        .timestamp {
            margin-top: 1.5rem;
            text-align: center;
            font-family: 'DM Mono', monospace;
            font-size: 0.65rem;
            color: var(--text-muted);
            letter-spacing: 0.05em;
        }
    </style>
    <div class="card">

        <div class="icon-badge">
            <!-- Checkmark / refund icon -->
            <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 7H9a2 2 0 0 0-2 2v9" />
                <path d="M14 3l-4 4 4 4" />
                <path d="M4 17l2 2 4-4" />
            </svg>
        </div>

        <span class="tag">Stripe · Refund</span>
        <h1>Refund Initiated</h1>
        <p class="subtitle">
            The refund has been submitted to Stripe and is being processed.
            Funds typically appear within 5–10 business days.
        </p>

        <div class="divider"></div>

        <div class="detail-list">
            <div class="detail-row">
                <span class="detail-label">Order ID</span>
                <span class="detail-value highlight">#@ViewData["OrderId"]</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Transaction</span>
                <span class="detail-value">@ViewData["TransactionId"]</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Amount</span>
                <span class="detail-value highlight">@ViewData["Amount"]</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Reason</span>
                <span class="detail-value badge">Unknown</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Status</span>
                <span class="detail-value highlight">Processing</span>
            </div>
        </div>

        <div class="alert">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="8" x2="12" y2="12"/>
                <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <p>
                This action is irreversible. The refund has already been submitted to Stripe.
                Contact support if this was made in error.
            </p>
        </div>

        <div class="actions">
            <a href="/orders" class="btn btn-ghost">
                ← Back to Orders
            </a>
            <a href="/dashboard" class="btn btn-primary">
                Dashboard →
            </a>
        </div>

        <p class="timestamp">Processed at @DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm:ss") UTC</p>
    </div>
